    {"file": "fe_assets_message/story.bytes.bundle:Chapter01.msbt", "label": "STR_0001", "text": "A millennium ago, four kingdoms joined forces to seal away the Fell Dragon."},
    {"file": "fe_assets_message/story.bytes.bundle:Chapter01.msbt", "label": "STR_0002", "text": "The Divine Dragon, who led the battle, fell into a deep slumber."},
    {"file": "fe_assets_message/story.bytes.bundle:Chapter01.msbt", "label": "STR_0003", "text": "Now, a thousand years later, the seal weakens..."},
    {"file": "fe_assets_message/story.bytes.bundle:Chapter01.msbt", "label": "STR_0004", "text": "Divine One! You've finally awakened!"},
    {"file": "fe_assets_message/story.bytes.bundle:Chapter01.msbt", "label": "STR_0005", "text": "The Emblem Rings... They hold the power of heroes from other worlds."},
    {"file": "fe_assets_message/story.bytes.bundle:Chapter01.msbt", "label": "STR_0006", "text": "We must collect all twelve rings before the enemy does!"},
    {"file": "fe_assets_message/story.bytes.bundle:Chapter01.msbt", "label": "STR_0007", "text": "The fate of Elyos rests in your hands."},
    {"file": "fe_assets_message/story.bytes.bundle:Chapter01.msbt", "label": "STR_0008", "text": "I won't let anyone destroy this world!"},
    {"file": "fe_assets_message/story.bytes.bundle:Chapter01.msbt", "label": "STR_0009", "text": "Together with our Emblem allies, we will prevail!"},
    {"file": "fe_assets_message/story.bytes.bundle:Chapter01.msbt", "label": "STR_0010", "text": "The battle for Elyos begins now!"},
